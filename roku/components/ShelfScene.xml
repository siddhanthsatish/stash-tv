<?xml version="1.0" encoding="utf-8" ?>
<component name="ShelfScene" extends="Scene">
    <script type="text/brightscript" uri="pkg:/source/ShelfScene.brs"/>
    <script type="text/brightscript" uri="pkg:/source/TMDBService.brs"/>
    <script type="text/brightscript" uri="pkg:/source/FirestoreService.brs"/>
    <script type="text/brightscript" uri="pkg:/source/config.brs"/>
    <children>
        <Label
            id="headerLabel"
            text="🎬 STASH"
            translation="[0, 30]"
            width="1920"
            horizAlign="center"
            font="font:LargeBoldSystemFont"
            color="0xFFFFFFFF"
        />
        <Label
            id="subLabel"
            text="Loading your shelf..."
            translation="[60, 90]"
            font="font:MediumSystemFont"
            color="0xAAAAAAFF"
        />
        <!-- Row 0, Col 0 -->
        <CategoryRow id="row0" translation="[60, 130]"/>
        <!-- Row 0, Col 1 -->
        <CategoryRow id="row1" translation="[1000, 130]"/>
        <!-- Row 1, Col 0 -->
        <CategoryRow id="row2" translation="[60, 570]"/>
        <!-- Row 1, Col 1 -->
        <CategoryRow id="row3" translation="[1000, 570]"/>

        <DetailScene
            id="detailScene"
            visible="false"
        />
    </children>
</component> 